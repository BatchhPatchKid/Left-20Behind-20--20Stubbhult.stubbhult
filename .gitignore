# ==============================
# Arma 3 Mission .gitignore
# ==============================

# Root-level folders to ignore
/sounds/
/PF/
/pics/
/codex.patch
/notes.TXT

# Packed / build artifacts
*.pbo
*.bisign
*.bikey

# Logs
*.rpt
*.log

# Temporary / backup files
*.bak
*.backup
*.tmp
*~

# Windows system files
Thumbs.db
Desktop.ini